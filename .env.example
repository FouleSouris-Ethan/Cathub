# PostgreSQL configuration
POSTGRES_USER=pawuser
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=pawplatform
DB_HOST=db
DB_PORT=5432

# Database URL (leave as-is for docker-compose, change only for local dev)
DATABASE_URL=postgresql://pawuser:your_secure_password_here@db:5432/pawplatform

# Uvicorn configuration
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Environment
ENV=development
